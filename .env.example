# -----------------------------------------------------------------------------
# Core runtime
# -----------------------------------------------------------------------------
# HTTP port exposed by the API service.
PORT=8000

# Application mode. Use production for container/self-hosted deployments.
NODE_ENV=development

# Winston log level: error, warn, info, http, verbose, debug, silly.
LOG_LEVEL=info

# MongoDB connection string used for documents, chunk metadata, and logs.
MONGODB_URI=mongodb://localhost:27017/rag-chatbot

# MongoDB database name.
MONGODB_DB_NAME=rag

# Redis connection string used by BullMQ for ingestion jobs.
REDIS_URL=redis://localhost:6379/0

# Qdrant base URL used for vector storage and retrieval.
QDRANT_URL=http://localhost:6333

# Required: OpenAI API key used for embeddings and chat completions.
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Model selection
# -----------------------------------------------------------------------------
# Embedding model used during ingestion and search.
EMBEDDING_MODEL=text-embedding-3-small

# Chat completion model used for grounded responses.
LLM_MODEL=gpt-4o-mini

# When true, the assistant may explicitly use external knowledge when retrieval is weak.
ALLOWED_EXTERNAL_SEARCH_SOURCES=false

# -----------------------------------------------------------------------------
# HTTP / API hardening
# -----------------------------------------------------------------------------
# Comma-separated list of allowed browser origins for CORS.
ALLOWED_ORIGINS=http://localhost:3000

# Fixed-window API rate limiting.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Request size and upstream timeout guards.
REQUEST_BODY_LIMIT_BYTES=1048576
REQUEST_TIMEOUT_MS=60000
OPENAI_TIMEOUT_MS=30000
QDRANT_TIMEOUT_MS=10000

# -----------------------------------------------------------------------------
# Upload limits
# -----------------------------------------------------------------------------
# Maximum size per uploaded file or pasted text payload.
UPLOAD_MAX_FILE_SIZE_BYTES=5242880

# Maximum number of files accepted in a single request.
UPLOAD_MAX_FILES=5

# Comma-separated MIME types/extensions accepted by upload validation.
UPLOAD_ALLOWED_MIME_TYPES=text/plain,text/markdown
UPLOAD_ALLOWED_EXTENSIONS=.txt,.md,.markdown

# -----------------------------------------------------------------------------
# Ingestion + retrieval tuning
# -----------------------------------------------------------------------------
# BullMQ worker parallelism.
INGEST_CONCURRENCY=2

# Retry policy for failed ingestion jobs.
INGEST_JOB_ATTEMPTS=3
INGEST_JOB_BACKOFF_MS=2000

# OpenAI embedding batching controls.
EMBED_BATCH_SIZE=50
EMBED_BATCH_MAX_INPUT_CHARS=200000

# Retrieval fan-out and optional lexical reranking.
RAG_TOP_K=6
RAG_RERANK_ENABLED=false
RAG_RERANK_TOP_N=3

# Token chunking configuration for ingestion.
CHUNK_MAX_TOKENS=2000
CHUNK_OVERLAP_TOKENS=200
CHUNKING_MODE=sentence

# Vector storage settings.
QDRANT_COLLECTION_NAME=default
QDRANT_PAYLOAD_TEXT_MAX_CHARS=3000

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# Local path for uploaded files. In Docker Compose this is overridden to /app/uploads.
STORAGE_PATH=./uploads